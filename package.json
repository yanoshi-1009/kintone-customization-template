{
  "name": "kintone-customization",
  "version": "1.0.0",
  "description": "This is my kintone customization template.",
  "keywords": [
    "kintone"
  ],
  "author": "y.idakko@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanoshi-1009/kintone-customization-template"
  },
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=26.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=26.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "init": "node ./scripts/init.ts",
    "build:prod": "tsc --noEmit && node ./scripts/esbuild/build.ts --mode=production",
    "build:dev": "tsc --noEmit && node ./scripts/esbuild/build.ts --mode=development"
  },
  "dependencies": {
    "@kintone/rest-api-client": "6.2.0",
    "dayjs": "1.11.21",
    "kintone-ui-component": "1.25.0"
  },
  "devDependencies": {
    "@cybozu/eslint-config": "25.0.1",
    "@kintone/dts-gen": "9.0.7",
    "@types/node": "24.13.2",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "prettier": "3.8.4",
    "typescript": "6.0.3"
  }
}
