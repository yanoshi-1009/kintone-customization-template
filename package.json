{
  "name": "kintone-customization",
  "version": "1.0.0",
  "description": "This is my kintone customization template.",
  "keywords": [
    "kintone"
  ],
  "author": "y.idakko@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanoshi-1009/kintone-customization-template"
  },
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "init": "node ./scripts/init.ts",
    "build:prod": "tsc --noEmit && node ./scripts/esbuild/build.ts --mode=production",
    "build:dev": "tsc --noEmit && node ./scripts/esbuild/build.ts --mode=development"
  },
  "dependencies": {
    "@kintone/rest-api-client": "6.1.3",
    "axios": "1.14.0",
    "dayjs": "1.11.20",
    "kintone-ui-component": "1.24.0"
  },
  "devDependencies": {
    "@cybozu/eslint-config": "25.0.1",
    "@kintone/dts-gen": "9.0.2",
    "@types/node": "24.12.0",
    "esbuild": "0.27.4",
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "typescript": "6.0.2"
  }
}
